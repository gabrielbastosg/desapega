# Copie este arquivo para .env e preencha com seus valores reais.
# O .env de verdade NUNCA vai pro Git (está no .gitignore).

# Credenciais do usuário IAM com acesso só ao bucket de mídia
AWS_ACCESS_KEY_ID=coloque-sua-access-key-aqui
AWS_SECRET_ACCESS_KEY=coloque-sua-secret-key-aqui
AWS_STORAGE_BUCKET_NAME=nome-do-seu-bucket-s3
